# PayOrder W3 Guardian — local Docker stack environment (TASK-027 / spec 12).
# Copy to `infra/docker/.env.local` and adjust. NEVER commit real secrets (only this *.example).
#
# This single file drives both Compose interpolation (POSTGRES_*, NEXT_PUBLIC_* build args) and
# the api/worker container runtime (env_file). Service hostnames are the Compose service names.

# --- Postgres (container) ---
POSTGRES_USER=payorder
POSTGRES_PASSWORD=payorder
POSTGRES_DB=payorder

# --- API / worker runtime ---
NODE_ENV=development
API_PORT=3000
APP_BASE_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3001
LOG_LEVEL=info

# Persistence — hosts are the Compose service names (`postgres`, `redis`).
DATABASE_URL=postgres://payorder:payorder@postgres:5432/payorder
REDIS_URL=redis://redis:6379

# Security — change these locally; they must be set per environment in VPS/CI.
JWT_SECRET=change-me-local
WEBHOOK_SIGNING_SECRET=change-me-local
CORS_ORIGINS=http://localhost:3001

# --- Stellar / Soroban (public Testnet) ---
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
SOROBAN_CONTRACT_ID=          # filled in after deploying the contract to Testnet
SOROBAN_ADMIN_SECRET=         # NEVER commit; Testnet admin account secret (S...) — worker only

# Register orders on-chain synchronously (handy locally) instead of via the worker queue.
REGISTER_ON_CHAIN_SYNC=false

# --- Frontend (NEXT_PUBLIC_* are inlined at web build time → Compose build args) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet
# Server-side (SSR) API URL: from inside the web container `localhost:3000` is the web container
# itself, so SSR must reach the API by its service name over the internal network.
API_INTERNAL_BASE_URL=http://api:3000

# --- Seed (make seed) — local-only placeholder credentials ---
SEED_ADMIN_EMAIL=admin@payorder.local
SEED_ADMIN_PASSWORD=changeme123
SEED_TENANT_WALLET=GB2JSQ55C76FBGEA4SJ6J4AQUWMNXEB25GVLK6W5CVEEJRUG2UCK4KUZ

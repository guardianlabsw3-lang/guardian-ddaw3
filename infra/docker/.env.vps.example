# PayOrder W3 Guardian — VPS environment (TASK-028 / spec 13). Copy to `infra/docker/.env.vps`
# on the VPS and fill in. NEVER commit real secrets (only this *.example file is tracked).
#
# This file feeds both Compose interpolation (REGISTRY, *_DOMAIN, TRAEFIK_NETWORK, POSTGRES_*)
# and the container runtime (env_file). Pass it with `--env-file infra/docker/.env.vps`.

# --- Images / registry ---
REGISTRY=ghcr.io/guardianlabsw3-lang
IMAGE_TAG=latest

# --- Existing Traefik (confirm the real network name with `docker network ls`) ---
# `proxy` is the shared ingress network created by the other product's stack; it
# is the default in docker-compose.traefik.yml. Only the label-based
# docker-compose.vps.yml reads CERT_RESOLVER — the file-provider Traefik uses the
# resolver hardcoded in infra/traefik/payorder_dynamic.toml (`le`). WEB_DOMAIN /
# API_DOMAIN must match the hosts in that toml.
TRAEFIK_NETWORK=proxy
CERT_RESOLVER=le
WEB_DOMAIN=pow3.guardian-labs.xyz
API_DOMAIN=api-pow3.guardian-labs.xyz

# --- Postgres (isolated) ---
POSTGRES_USER=payorder
POSTGRES_PASSWORD=__set_in_env__
POSTGRES_DB=payorder

# --- API / worker runtime ---
NODE_ENV=production
API_PORT=3000
LOG_LEVEL=info
# Hosts are the prefixed container names on the private network.
DATABASE_URL=postgres://payorder:__set_in_env__@payorder_postgres:5432/payorder
REDIS_URL=redis://payorder_redis:6379

APP_BASE_URL=https://api-pow3.guardian-labs.xyz
PUBLIC_WEB_URL=https://pow3.guardian-labs.xyz
JWT_SECRET=__set_in_env__
WEBHOOK_SIGNING_SECRET=__set_in_env__
CORS_ORIGINS=https://pow3.guardian-labs.xyz

# --- Stellar Testnet ---
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
SOROBAN_CONTRACT_ID=__set_after_deploy__
SOROBAN_ADMIN_SECRET=__set_in_env__
REGISTER_ON_CHAIN_SYNC=false

# --- Frontend (NEXT_PUBLIC_* are baked into payorder-web at CI build time, per environment) ---
NEXT_PUBLIC_API_BASE_URL=https://api-pow3.guardian-labs.xyz
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet
# Server-side (SSR) API URL — runtime only, NOT baked into the browser bundle. The public domain
# above may not hairpin back from inside the web container, so SSR reaches the API over the shared
# Traefik network. Use the UNIQUE container name (not a bare `api` alias, which could collide with
# the other product on the shared `proxy` network); the api listens on port 3000.
API_INTERNAL_BASE_URL=http://payorder_api:3000

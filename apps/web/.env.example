# PayOrder W3 Guardian — web (frontend) environment.
# Only NEXT_PUBLIC_* variables are exposed to the browser. Testnet only.

# Base URL of the PayOrder REST API (no trailing slash). The app calls `${API}/api/...`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Stellar Testnet endpoints used for the non-custodial payment (client-side signing).
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Block/contract explorer base used for "view on explorer" links.
NEXT_PUBLIC_EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet

{
  "name": "@payorder/api",
  "version": "0.0.0",
  "private": true,
  "description": "PayOrder W3 Guardian — REST API: framework-free HTTP edge, auth, idempotency, rate limiting, webhooks, OpenAPI (TASK-010..024).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/persistence/migrate.ts"
  },
  "dependencies": {
    "@payorder/shared": "*",
    "@stellar/stellar-sdk": "^13.3.0",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.38.3",
    "hash-wasm": "^4.12.0",
    "postgres": "^3.4.5",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}

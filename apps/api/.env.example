# PayOrder W3 Guardian — API environment (Testnet only).
# Copy to `.env` and fill in. NEVER commit real secrets (only this *.example file).

# --- Runtime ---
NODE_ENV=development
API_PORT=3000
APP_BASE_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3001
LOG_LEVEL=info

# --- Persistence ---
DATABASE_URL=postgres://payorder:payorder@localhost:5432/payorder
REDIS_URL=redis://localhost:6379

# --- Security ---
JWT_SECRET=change-me-local
WEBHOOK_SIGNING_SECRET=change-me-local
CORS_ORIGINS=http://localhost:3001

# --- Stellar / Soroban (Testnet) ---
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
SOROBAN_CONTRACT_ID=        # filled in after deploying the contract to Testnet
SOROBAN_ADMIN_SECRET=       # NEVER commit; Testnet admin account of the contract

# --- Behaviour flags ---
# Register orders on-chain synchronously (tests/local) instead of via the worker queue.
REGISTER_ON_CHAIN_SYNC=false

# PayOrder W3 Guardian — worker environment (Testnet only).
# Copy to `.env` and fill in. NEVER commit real secrets (only this *.example file).
#
# The worker shares the api's environment schema (Testnet-locked). It additionally REQUIRES a
# deployed contract id and the admin secret that authorizes `register_order`.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Persistence (shared with the api) ---
DATABASE_URL=postgres://payorder:payorder@localhost:5432/payorder
REDIS_URL=redis://localhost:6379

# --- Security (validated by the shared schema; unused by the worker itself) ---
JWT_SECRET=change-me-local
WEBHOOK_SIGNING_SECRET=change-me-local
APP_BASE_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3001

# --- Stellar / Soroban (Testnet) ---
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_CONTRACT_ID=        # REQUIRED: deployed PayOrder contract id (C...)
SOROBAN_ADMIN_SECRET=       # REQUIRED: NEVER commit; Testnet admin account secret (S...)

# --- Scheduling (milliseconds; optional, sensible defaults applied) ---
SYNC_INTERVAL_MS=30000      # status reconciliation sweep interval
EXPIRE_INTERVAL_MS=60000    # expiration sweep interval

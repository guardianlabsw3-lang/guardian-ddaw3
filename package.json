{
  "name": "payorder-w3-guardian",
  "version": "0.0.0",
  "private": true,
  "description": "PayOrder W3 Guardian — Structured Payment DDA on Web3 (Stellar Testnet).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
